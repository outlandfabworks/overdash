	(text "Each channel does the same job: convert a 12V car signal into a 3.3V Pi-safe GPIO reading."
		(exclude_from_sim no)
		(at 10 168 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0000013e-013e-0000-0000-00000000013e")
	)
	(text ""
		(exclude_from_sim no)
		(at 10 171 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0000013f-013f-0000-0000-00000000013f")
	)
	(text "1. TVS DIODE (SMAJ15A)  — Clamps voltage spikes from the car wiring to a safe 15V maximum."
		(exclude_from_sim no)
		(at 12 174 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000140-0140-0000-0000-000000000140")
	)
	(text "                           Cars generate large spikes when loads switch — this absorbs them."
		(exclude_from_sim no)
		(at 12 178 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000141-0141-0000-0000-000000000141")
	)
	(text "2. 560 OHM RESISTOR     — Limits the current through the optocoupler LED to ~20mA at 12V."
		(exclude_from_sim no)
		(at 12 182 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000142-0142-0000-0000-000000000142")
	)
	(text "                           Without this the LED would burn out immediately."
		(exclude_from_sim no)
		(at 12 186 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000143-0143-0000-0000-000000000143")
	)
	(text "3. PC817 OPTOCOUPLER    — The key safety component. Uses a tiny LED + phototransistor."
		(exclude_from_sim no)
		(at 12 190 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000144-0144-0000-0000-000000000144")
	)
	(text "                           Car wiring drives the LED. Pi reads the transistor output."
		(exclude_from_sim no)
		(at 12 194 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000145-0145-0000-0000-000000000145")
	)
	(text "                           There is NO electrical connection between car and Pi sides."
		(exclude_from_sim no)
		(at 12 198 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000146-0146-0000-0000-000000000146")
	)
	(text "4. 10K PULL-UP RESISTOR — Holds the GPIO pin at 3.3V when no car signal is present."
		(exclude_from_sim no)
		(at 12 202 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000147-0147-0000-0000-000000000147")
	)
	(text "5. 1K RESISTOR + LED    — Status indicator. Glows when the channel is receiving a signal."
		(exclude_from_sim no)
		(at 12 206 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000148-0148-0000-0000-000000000148")
	)
	(text "                           Useful during wiring: confirm signals without a multimeter."
		(exclude_from_sim no)
		(at 12 210 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "00000149-0149-0000-0000-000000000149")
	)
